{
  "name": "proofmode-ai-monorepo",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm -w apps/web run build",
    "dev": "npm -w apps/web run dev",
    "lint": "npm -w apps/web run lint",
    "typecheck": "npm -w apps/web run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
