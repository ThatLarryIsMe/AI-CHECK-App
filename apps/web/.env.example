# Phase C - LLM-only verification engine
# Copy this file to .env.local and fill in values

# Required: OpenAI API key for LLM-based claim extraction and classification
OPENAI_API_KEY=

# Engine version tag (used in EvidencePack metadata)
ENGINE_VERSION=1.0.0-lite


# Phase F1 — Postgres DB connection
# Required for waitlist persistence (and Phase F2 for jobs/packs)
# Get this from your Neon/Supabase/Postgres provider
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Phase J — Optional Brave Search retrieval
BRAVE_API_KEY=

# Phase K — Invite-only beta gate
BETA_ACCESS_KEY=
