{
  "manifest_version": 3,
  "name": "Factward — Inline Fact-Checker",
  "version": "0.1.0",
  "description": "Highlight claims on any webpage and verify them against real sources with Factward.",
  "permissions": ["storage", "activeTab", "contextMenus", "scripting", "notifications"],
  "host_permissions": ["https://factward.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
